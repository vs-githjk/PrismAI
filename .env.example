# Frontend environment variables (Vite). Copy to .env and fill in.
# The backend base URL the app talks to (e.g. http://localhost:8000)
VITE_API_URL=
# Supabase project (anon/public key only — never the service-role key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# OAuth client IDs (public)
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
