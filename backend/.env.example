# ── AI / Transcription ─────────────────────────────────────────────
# Claude Haiku 4.5 runs the analysis agents + RAG; OpenAI runs the chat/live-bot
# tool-calling, audio transcription (whisper-1), and embeddings (and is the
# cross-provider fallback for the agents). Both are required.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Meeting Bot (Recall.ai) ────────────────────────────────────────
# Only required if the live meeting bot feature is used.
RECALL_API_KEY=your_recall_api_key_here
WEBHOOK_BASE_URL=https://meeting-copilot-api.onrender.com

# ── Live Transcript (Deepgram) ─────────────────────────────────────
# Required for real-time transcript streaming during live meetings.
# Free tier at deepgram.com ($200 credit, no credit card required).
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Voice Responses (ElevenLabs) ──────────────────────────────────
# Optional — bot responds via chat text if not set.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Voice agent — mouth (Cartesia TTS) ─────────────────────────────
# Streaming TTS for the realtime voice pipeline (backend/voice/). Voice id has
# no default — set it to the Cartesia voice you want the bot to speak with.
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=

# ── Voice agent — talk brain (Groq) ────────────────────────────────
# The Phase-3 voice channel: a tool-less, streaming conversational brain where
# Groq's fast time-to-first-token is the whole point. Optional — if unset, the
# voice channel falls back to OpenAI gpt-4o-mini (slower first token, still works).
# Free tier has a 100k-tokens/day cap; a busy live-meeting day can brush it.
GROQ_API_KEY=gsk-your-groq-key-here

# Phase 3 — two-channel brain (voice channel + agent channel + command bus). Default
# OFF: the fused `_process_command` stays the live path until a real meeting validates
# the split. Set to 1 for the first live join, then it becomes the default.
PRISM_TWO_CHANNEL=0
# Voice-channel talk model (Groq). Drop to llama-3.1-8b-instant if TTFT disappoints.
PRISM_VOICE_MODEL=llama-3.3-70b-versatile

# Phase 4 — single engagement gate (Auto/Manual), replacing the scattered
# wake-word/solo/ambient decisions. Default OFF: the legacy detection stays the live
# path until a real meeting validates the gate. Independent of PRISM_TWO_CHANNEL
# (the gate decides "speak?", the brain flag decides how the command is handled).
PRISM_ENGAGEMENT_GATE=0

# ── Voice agent — Phase 5 feel knobs ───────────────────────────────────────
# Everything below is OPTIONAL: the defaults are in backend/voice/tuning.py, seeded from
# Curio's proven values. Set one here only to turn it between meetings. `voice/tuning.py`
# documents what each does; the live values are printed once per pipeline start.
#
# Barge-in (§1). Sustained speech this long over the bot = a real interruption; shorter
# bursts are backchannels ("yeah", "mm-hm") and are ignored. PRISM_VOICE_BARGE_IN=0 falls
# back to Flux's interrupt-on-any-turn-start.
# PRISM_BARGE_MIN_SPEECH_MS=500
# PRISM_VOICE_BARGE_IN=1
#
# Politeness gap (§2) — how long the room must be acoustically quiet before the bot
# starts talking, and the never-hang cap. PRISM_GAP_WAIT=0 disables the wait entirely.
# PRISM_GAP_SILENCE_S=1.2
# PRISM_GAP_MAX_WAIT_S=4.0
#
# Latency (§3). Setting the eager threshold (below PRISM_FLUX_EOT_THRESHOLD, try 0.5)
# turns ON the speculative voice-channel call: the talk brain starts on Flux's early
# guess at the turn's end and is thrown away if the human keeps going. Expected 200–400ms
# off first audio, paid for in discarded LLM calls. UNSET = off, which is Flux's default.
# PRISM_FLUX_EAGER_EOT_THRESHOLD=0.5
# PRISM_FLUX_EOT_THRESHOLD=0.7
# PRISM_FLUX_EOT_TIMEOUT_MS=5000
#
# Voice & delivery (§4). Emotion is applied to EVERY sentence — leave unset and let
# Sonic-3 infer delivery from the words.
# PRISM_TTS_SPEED=1.0
# PRISM_TTS_VOLUME=1.0
# PRISM_TTS_EMOTION=
# PRISM_SPOKEN_MAX_SENTENCES=3
# PRISM_SPOKEN_MAX_CHARS=340

# ── Database (Supabase) ────────────────────────────────────────────
# Use the service_role key here — it bypasses RLS and must NEVER go to the frontend.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
# Optional — only needed to enable local JWT validation (PRISM_LOCAL_JWT=1).
# Find this in Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret.
# When set AND the flag is on, require_user_id verifies tokens with HS256
# locally instead of round-tripping to Supabase's /auth/v1/user. Every local
# failure transparently falls back to remote validation, so a bad/missing
# secret never locks the app out.
SUPABASE_JWT_SECRET=
# Set to 1 to enable the local JWT fast-path. Saves ~70ms per authenticated
# request but bypasses Supabase's session-revocation list (signed-out tokens
# remain valid until their `exp` lapses — typically ≤1 hour).
PRISM_LOCAL_JWT=0

# Shared workspace-membership cache (caches.py). Used by knowledge_service,
# knowledge_routes, recall_routes, and storage_routes to collapse the
# "what workspaces does this user belong to?" query (called on every
# /knowledge/docs, /meetings, /insights, /join-meeting, knowledge_lookup
# tool invocation) into one DB read per user per TTL window.
# Flip to 0 for emergency rollback — no redeploy needed.
PRISM_WORKSPACE_CACHE=1
PRISM_WORKSPACE_CACHE_TTL_S=300

# Analysis pipeline efficiency knobs (analysis_service.py).
#
# Skip the orchestrator's LLM call when the transcript is at least this many
# words — long meetings essentially always run every agent anyway, so the
# orchestrator's decision-cost (~500-800ms + tokens) doesn't pay for itself.
# Tune lower to be more aggressive, higher to keep the orchestrator's
# selective behavior on shorter meetings. Set to a very large number
# (e.g. 99999) to effectively disable the fast-path.
PRISM_SKIP_ORCH_WORDS=1500
#
# When 1, the email_drafter tier-2 agent synthesizes from context only
# (summary + decisions + action_items) rather than re-reading the full
# transcript. Saves roughly one transcript-sized input per meeting. Flip to
# 0 if email quality regresses — no redeploy needed.
PRISM_EMAIL_FROM_CONTEXT=1

# ── Google Calendar OAuth ──────────────────────────────────────────
# Required for the /calendar/exchange-code endpoint (PKCE token exchange).
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── LangGraph / LangSmith ──────────────────────────────────────────
# LangSmith tracing is opt-in. Set to true only if you have a LangSmith API key
# and want to trace graph executions. Leave false (or unset) in production.
LANGSMITH_TRACING=false
# ── Knowledge Base / RAG (merged from fixed-changes) ───────────────
# OpenAI runs embeddings (text-embedding-3-small), the chat + live-bot tool-calling
# (gpt-4o-mini), whisper transcription, and the agents' cross-provider fallback.
OPENAI_API_KEY=sk-your-openai-key-here
# Tavily powers web_search (RAG fallback) and URL document extraction.
# Free tier: 1,000 calls/month. https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here
