# ── Backend API ────────────────────────────────────────────────────
# Points the frontend at the FastAPI backend.
VITE_API_URL=https://meeting-copilot-api.onrender.com

# ── Supabase (frontend-safe values only) ──────────────────────────
# Required once Google SSO / auth is added (roadmap #4).
# Use the anon key here — it is safe to expose in the browser.
# NEVER put the service_role key in Vercel or any frontend env var.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Google Calendar (direct PKCE flow) ────────────────────────────
# The OAuth 3.0 Client ID from Google Cloud Console (safe to expose in browser).
# The redirect URI must be added to Authorized redirect URIs in Google Cloud Console.
# Production: https://agentic-meeting-copilot.vercel.app
# Local dev:  http://localhost:5174
VITE_GOOGLE_CLIENT_ID=


